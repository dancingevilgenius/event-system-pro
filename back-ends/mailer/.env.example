# Mailer service for Event System Pro
#
# Copy to .env and adjust:
#   copy .env.example .env

PORT=3001

# PostgreSQL (mailer role — see database/migrations/010_mailer_password_reset.sql)
DATABASE_URL=postgres://mailer:mailer_dev_password@host.docker.internal:5432/event_system_pro

# SMTP — local Mailpit (docker compose) captures mail at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

EMAIL_FROM=Event System Pro <no-reply@eventsystempro.local>
APP_NAME=Event System Pro

# Comma-separated browser origins (Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production examples:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
