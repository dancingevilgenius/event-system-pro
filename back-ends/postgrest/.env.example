# Copy to .env and adjust for your machine.
#   copy .env.example .env

# PostgreSQL connection (authenticator role — see database/migrations/003_postgrest_api.sql)
PGRST_DB_URI=postgres://authenticator:postgrest_dev_password@host.docker.internal:5432/event_system_pro

# Expose only the api schema (views), not raw public tables.
PGRST_DB_SCHEMAS=api
PGRST_DB_ANON_ROLE=anon
PGRST_DB_POOL=10

PGRST_SERVER_HOST=0.0.0.0
PGRST_SERVER_PORT=3000
PGRST_OPENAPI_SERVER_PROXY_URI=http://localhost:3000

# CORS: Swagger UI + Vite dev server (localhost and 127.0.0.1 are different origins).
PGRST_SERVER_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# JWT — required for authenticated API calls (Bearer token from login).
# Must match database app.jwt_secret (database/migrations/018_auth_rbac.sql).
PGRST_JWT_SECRET=esp-dev-jwt-secret-change-in-production-min-32-chars

# Realtime POC (admin home counter) — exposed on host port 3002; Vite proxies /realtime to it.
REALTIME_PORT=3002
