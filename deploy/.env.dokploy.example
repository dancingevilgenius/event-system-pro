# Dokploy environment variables (paste into the Dokploy app Environment tab).
# Test target: https://imake.wtf (eventsystem.pro stays on EventSystemPro).
#
# POSTGRES_PASSWORD: choose once and keep stable (required for postgres superuser).
# Role passwords below MUST match migration defaults on a fresh database.

APP_URL=https://imake.wtf

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-long-random-postgres
POSTGRES_DB=event_system_pro

# Must match migrations 003 / 010 / 029 (do not change on fresh deploy unless you ALTER ROLE in SQL).
PGRST_AUTHENTICATOR_PASSWORD=postgrest_dev_password
MAILER_DB_PASSWORD=mailer_dev_password
REALTIME_DB_PASSWORD=realtime_dev_password

# Must match database app.jwt_secret (migration 018). At least 32 characters.
PGRST_JWT_SECRET=esp-dev-jwt-secret-change-in-production-min-32-chars

# Baked into the web image at build time (redeploy after changing).
VITE_POSTGREST_URL=https://imake.wtf/api
VITE_MAILER_URL=https://imake.wtf/mailer
VITE_REALTIME_WS_URL=wss://imake.wtf/realtime/ws

CORS_ORIGINS=https://imake.wtf
