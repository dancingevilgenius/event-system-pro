# Dokploy environment variables (paste into the Dokploy app Environment tab).
# Test target: https://eventsystem.fun (eventsystem.pro stays on EventSystemPro).
#
# POSTGRES_PASSWORD: choose once and keep stable (required for postgres superuser).
# Role passwords below MUST match migration defaults on a fresh database.

APP_URL=https://eventsystem.fun
APP_DOMAIN=eventsystem.fun

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-long-random-postgres
POSTGRES_DB=event_system_pro

# Dev only: publish Postgres on VPS host port 5432 (open firewall; remove for production).
POSTGRES_PUBLISH_PORT=5432

# Must match migrations 003 / 010 / 029 / 104 (do not change on fresh deploy unless you ALTER ROLE in SQL).
PGRST_AUTHENTICATOR_PASSWORD=postgrest_dev_password
MAILER_DB_PASSWORD=mailer_dev_password
REALTIME_DB_PASSWORD=realtime_dev_password
SCHEDULER_DB_PASSWORD=scheduler_dev_password

# Must match database app.jwt_secret (migration 018). At least 32 characters.
PGRST_JWT_SECRET=esp-dev-jwt-secret-change-in-production-min-32-chars

# Baked into the web image at build time (redeploy after changing).
VITE_POSTGREST_URL=https://eventsystem.fun/api
VITE_MAILER_URL=https://eventsystem.fun/mailer
VITE_REALTIME_WS_URL=wss://eventsystem.fun/realtime/ws

# Optional web image build metadata (Dokploy may set DOKPLOY_COMMIT_HASH automatically).
GIT_COMMIT=unknown
GIT_BRANCH=main
GITHUB_REPOSITORY=dancingevilgenius/event-system-pro
BUILD_DATE=
DOKPLOY_COMMIT_HASH=

CORS_ORIGINS=https://eventsystem.fun

# Optional: Mailpit web UI on VPS host port (dev/test — open firewall TCP 8025 to read reset codes).
MAILPIT_UI_PORT=8025

# eventsystem.fun test deploy: migrate runs database/seeds/dev.manifest after migrations.
# Set false for production-style deploys with an empty app database.
SEED_DEV_DATA=true

# eventsystem.fun only: enables api.admin_purge_audit_log (set false on production).
ALLOW_AUDIT_PURGE=true