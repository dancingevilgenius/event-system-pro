# Copy to deploy/.env before starting the stack:
#   copy deploy\.env.example deploy\.env
#
# From repo root:
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up --build
#
# Open http://localhost:8090

# PostgreSQL (container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=event_system_pro

# Must match passwords created in database/migrations/003 and 010 (dev defaults).
PGRST_AUTHENTICATOR_PASSWORD=postgrest_dev_password
MAILER_DB_PASSWORD=mailer_dev_password

# Must match database app.jwt_secret (migration 018). Change in production.
PGRST_JWT_SECRET=esp-dev-jwt-secret-change-in-production-min-32-chars

# Single public URL (reverse proxy entry point)
APP_URL=http://localhost:8090
APP_PORT=8090

# Baked into the web image at build time — paths go through the proxy
VITE_POSTGREST_URL=http://localhost:8090/api
VITE_MAILER_URL=http://localhost:8090/mailer

# Comma-separated browser origins allowed to call PostgREST and mailer
CORS_ORIGINS=http://localhost:8090,http://127.0.0.1:8090,http://localhost:5173,http://127.0.0.1:5173

# Dev email (still direct — not proxied)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Optional: expose backend ports directly for debugging (uncomment in compose if needed)
# PGRST_SERVER_PORT=3000
# MAILER_PORT=3001
# WEB_PORT=8088
