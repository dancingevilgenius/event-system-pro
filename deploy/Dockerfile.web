# Production static frontend: Vite build + nginx.
# Build from repo root:
#   docker build -f deploy/Dockerfile.web -t event-system-pro-web .

FROM node:22-alpine AS build

WORKDIR /app

COPY front-ends/front-end-cursor/package.json front-ends/front-end-cursor/package-lock.json ./
RUN npm ci

COPY front-ends/front-end-cursor/ ./

ARG VITE_POSTGREST_URL=http://localhost:3000
ARG VITE_MAILER_URL=http://localhost:3001
ARG VITE_REALTIME_WS_URL=ws://localhost:8090/realtime/ws
ENV VITE_POSTGREST_URL=$VITE_POSTGREST_URL
ENV VITE_MAILER_URL=$VITE_MAILER_URL
ENV VITE_REALTIME_WS_URL=$VITE_REALTIME_WS_URL

RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
